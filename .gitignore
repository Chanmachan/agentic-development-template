# ── OS / editor junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
.envrc

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Claude Code personal-scope project notes (not shared with team) ───────────
CLAUDE.local.md

# ── Task tracking — local working state ──────────────────────────────────────
# Convention lives in .claude/rules/tasks.md.
# /tasks (no trailing slash) ignores both the real dir in the main checkout and
# the symlink that worktrees create pointing back to it (a trailing-slash pattern
# matches directories only, so it would miss the symlink).
# See scripts/sync-local-docs.sh.
/tasks

# ── Language-specific (uncomment what you need) ───────────────────────────────

# Node / JavaScript / TypeScript
# node_modules/
# dist/
# .next/
# .nuxt/
# coverage/

# Python
# __pycache__/
# *.py[cod]
# .venv/
# dist/
# *.egg-info/
# .mypy_cache/
# .ruff_cache/

# Go
# vendor/

# Rust
# target/

# Java / Kotlin / Gradle
# .gradle/
# build/
# *.class

# Ruby / Bundler
# .bundle/
# vendor/bundle/
